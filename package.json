{
  "name": "tokenomix",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,cyan \"pnpm --filter @tokenomix/server dev\" \"pnpm --filter @tokenomix/web dev\"",
    "build": "pnpm -r run build",
    "start": "pnpm --filter @tokenomix/server start",
    "start:full": "concurrently -n server,web -c blue,cyan \"pnpm --filter @tokenomix/server start\" \"pnpm --filter @tokenomix/web preview\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "typecheck": "pnpm -r run typecheck",
    "verify:pricing": "pnpm --filter @tokenomix/server verify:pricing"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
